# Copy this file to .env and fill in at least one compatible API key.

# Preferred for this demo
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
LLM_MODEL_ACTOR=deepseek-chat
LLM_MODEL_REWARD=deepseek-chat

# Optional fallback if you use an OpenAI-compatible endpoint.
OPENAI_API_KEY=your_openai_api_key_here
